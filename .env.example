# DeepSeek API 配置 (OpenAI Compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Stockfish 引擎路径
STOCKFISH_PATH=stockfish

# Stockfish 分析参数
STOCKFISH_DEPTH=18
STOCKFISH_THREADS=2
STOCKFISH_HASH=64

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=8501
